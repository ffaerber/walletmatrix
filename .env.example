# Optional Alchemy key — without it the scanner falls back to probing a
# fixed list of well-known ERC-20 contracts on each chain.
VITE_ALCHEMY_KEY=

# Set to `true` to enable real bridge / cross-chain swap execution via the
# Li.Fi public API and MetaMask (eth_sendTransaction). When unset, the
# Confirm button only mutates local balances (useful for development and
# screenshots). The demo wallet always uses local balances regardless.
VITE_ENABLE_REAL_TX=
