{
  "name": "walletmatrix",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Pivot-table view of your crypto wallet across every EVM chain. Swarm-deployable SPA.",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "typecheck": "tsc -b --noEmit",
    "preview": "vite preview",
    "deploy:swarm": "swarm-cli upload ./dist --stamp $SWARM_STAMP"
  },
  "dependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router": "^7.1.1"
  },
  "devDependencies": {
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "@vitejs/plugin-react": "^4.3.4",
    "typescript": "^5.7.2",
    "vite": "^6.0.7"
  }
}
